# Model weights — live in object storage, never in git
*.pth
*.onnx
*.safetensors
*.bin

# Vocabulary artifacts — live in object storage
**/vocab.json

# Secrets — NEVER commit
.env
.env.*
*.secret
secrets/
**/secrets/

# Terraform state (contains secrets, machine-generated)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Ansible vault / SSH keys
*.vault
id_rsa*
!id_rsa*.pub

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Benchmark / perf outputs
benchmark_results_*.json
perf_analyzer_*.csv

# Docker build artifacts
*.tardata/processed/
training/__pycache__/
**/__pycache__/
**/*.pyc
